{
  "name": "loadtoagent",
  "version": "1.3.6",
  "description": "A local desktop dashboard for Claude, Codex, Gemini, and Grok sessions.",
  "main": "main.js",
  "author": "wincube AX",
  "license": "UNLICENSED",
  "homepage": "https://github.com/minjund/LodeToAgent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minjund/LodeToAgent.git"
  },
  "bugs": {
    "url": "https://github.com/minjund/LodeToAgent/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "codex",
    "gemini",
    "grok",
    "electron",
    "desktop"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "main.js",
    "preload.js",
    "renderer",
    "src",
    "docs",
    "README.md",
    "README.ko.md",
    "README.zh-CN.md"
  ],
  "bin": {
    "loadtoagent": "bin/loadtoagent.js"
  },
  "scripts": {
    "start": "electron .",
    "test": "node scripts/regression-test.js",
    "test:terminal": "electron scripts/terminal-integration-test.js",
    "test:terminal:mac-stress": "node scripts/mac-terminal-stress-check.js",
    "test:terminal-restart": "node scripts/terminal-restart-persistence-check.js",
    "test:bridge": "electron scripts/bridge-integration-test.js",
    "test:tmux": "node scripts/tmux-integration-test.js",
    "test:visual": "electron scripts/visual-check.js",
    "test:responsive": "electron scripts/responsive-check.js",
    "test:interaction": "electron scripts/interaction-check.js",
    "test:scroll": "electron scripts/scroll-retention-check.js",
    "audit:ui": "electron scripts/browser-audit-host.js",
    "test:runtime-overview": "electron scripts/runtime-overview-visual.js",
    "test:control-room": "electron scripts/control-room-visual.js",
    "test:readability": "electron scripts/readability-visual-check.js",
    "test:update:mac": "node scripts/mac-update-integration-test.js",
    "test:artifacts:mac": "node scripts/mac-artifact-check.js",
    "demo:readme": "electron scripts/readme-demo.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "pack": "electron-builder --dir",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "1.2.0-beta.14"
  },
  "peerDependencies": {
    "electron": "^31.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.wincube.loadtoagent",
    "productName": "LoadToAgent",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "bin/**/*",
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "bin/**/*",
      "node_modules/node-pty/**/*"
    ],
    "afterPack": "scripts/after-pack.js",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "artifactName": "LoadToAgent-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "LoadToAgent-${version}-portable.exe",
      "unpackDirName": false
    },
    "nsis": {
      "artifactName": "LoadToAgent-Setup-${version}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": false
    }
  }
}
